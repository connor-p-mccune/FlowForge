# Copy this file to .env and fill in values before running.
# Never commit .env to version control.

JWT_SECRET=change-me-to-a-long-random-string-for-dev
OPENAI_API_KEY=sk-...
VITE_API_URL=http://localhost:3001

# URL the Node backend uses to reach the Python AI service.
AI_SERVICE_URL=http://localhost:5000

# Optional: how many nodes of one run may execute concurrently (independent
# branches of the graph). 1 = strictly sequential. Default 4.
# EXEC_MAX_PARALLEL=4

# Optional: bearer token required to scrape GET /metrics (Prometheus).
# Left unset, the endpoint is open — fine when the port isn't public.
# METRICS_TOKEN=

# Optional: dedicated key material for encrypting workspace secrets at rest
# (AES-256-GCM). Falls back to JWT_SECRET when unset. Changing it makes
# existing secrets undecryptable — rotate them afterwards.
# SECRETS_ENCRYPTION_KEY=

# Optional: real delivery for the Send Email node. Without SMTP_HOST, email
# sends are simulated (serialised and logged, not delivered).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=flowforge@example.com
