# Copy this file to .env and fill in values before running.
# Never commit .env to version control.

JWT_SECRET=change-me-to-a-long-random-string-for-dev
OPENAI_API_KEY=sk-...
VITE_API_URL=http://localhost:3001

# URL the Node backend uses to reach the Python AI service.
AI_SERVICE_URL=http://localhost:5000

# Optional: real delivery for the Send Email node. Without SMTP_HOST, email
# sends are simulated (serialised and logged, not delivered).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=flowforge@example.com
