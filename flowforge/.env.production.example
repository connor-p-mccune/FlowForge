# =============================================================================
# FlowForge — production environment variables
# =============================================================================
# These are NOT loaded from a file in production. Set each block in the dashboard
# of the platform that hosts that service:
#   - SERVER + AI-SERVICE  -> Railway service "Variables" tab
#   - CLIENT               -> Vercel project "Environment Variables"
# See DEPLOYMENT.md for the full walkthrough.
# Never commit real secrets — this file documents names only.


# -----------------------------------------------------------------------------
# SERVER  (Railway service: "server" — Node/Express, public)
# -----------------------------------------------------------------------------
# Long random string used to sign JWTs. Generate with: openssl rand -hex 32
# Keep it stable — changing it invalidates every issued login token.
JWT_SECRET=replace-with-a-long-random-string

# Public origin of the deployed client, used as the CORS / WebSocket allow-list.
# No trailing slash. Comma-separate to allow several (e.g. a custom domain plus
# the *.vercel.app URL). MUST match the browser address bar exactly.
FRONTEND_URL=https://your-app.vercel.app

# Redis connection string. On Railway, reference the Redis service's private URL
# (Variables tab -> Add Reference -> Redis -> REDIS_URL). Private host is IPv6.
REDIS_URL=redis://default:password@redis.railway.internal:6379

# Internal URL of the AI service over Railway's private network. Pin the AI
# service's PORT (below) so this stays stable. NOT a public URL.
AI_SERVICE_URL=http://ai-service.railway.internal:5000

# Absolute path to the SQLite file. MUST live inside the mounted volume directory
# (see DEPLOYMENT.md) or the database is wiped on every redeploy.
DATABASE_PATH=/app/data/flowforge.db

# Railway injects PORT automatically and the server reads it — do not hardcode.
# NODE_ENV=production is baked into the server Dockerfile.

# Optional: real email delivery for the Send Email node. Without SMTP_HOST the
# node simulates sends (serialised + logged, not delivered).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=flowforge@example.com


# -----------------------------------------------------------------------------
# AI-SERVICE  (Railway service: "ai-service" — Python/Flask, private only)
# -----------------------------------------------------------------------------
# OpenAI API key — the only required variable for this service.
OPENAI_API_KEY=sk-...

# Optional: override the model (defaults to gpt-4o-mini in code).
# OPENAI_MODEL=gpt-4o-mini

# Pin the listen port so the server's AI_SERVICE_URL above stays predictable.
# gunicorn binds [::]:$PORT (see Dockerfile). 5000 matches AI_SERVICE_URL.
PORT=5000


# -----------------------------------------------------------------------------
# CLIENT  (Vercel project — Vite static build)
# -----------------------------------------------------------------------------
# Public URL of the Railway "server" service. MUST be https:// (the Vercel site
# is https, so an http value triggers mixed-content blocking and breaks both the
# API and the WebSocket). One variable covers REST + Socket.io.
# Vite inlines this at BUILD time — change it => redeploy the client to rebuild.
VITE_API_URL=https://your-server.up.railway.app
